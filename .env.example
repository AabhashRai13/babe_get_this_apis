# Copy this file to `.env` and fill in your keys.
#   cp .env.example .env

# development (default) | production. In production both keys are required and
# the app refuses to start without them; the browser test page is disabled.
NODE_ENV=development

PORT=4827

# Claude (text -> structured items). Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_claude_api_key_here

# Groq (Whisper: audio -> text). Get a key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Supabase (auth: validates the Bearer JWT on POST /transcribe). Project Settings
# -> API. Use the anon/publishable key, never the service_role key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
